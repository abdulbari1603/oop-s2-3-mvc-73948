@model VcgCollege.Web.Data.Entities.Exam
@{
    ViewData["Title"] = "Delete exam";
}
<h1 class="h3 mb-3">Delete exam</h1>
<p>Are you sure you want to delete <strong>@Model.Title</strong>? All exam results will be removed.</p>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-action="Course" asp-route-id="@Model.CourseId">Cancel</a>
</form>
