@model VcgCollege.Web.Data.Entities.Branch
@{
    ViewData["Title"] = "Branch details";
}
<h1 class="h3 mb-3">@Model.Name</h1>
<dl class="row">
    <dt class="col-sm-2">Address</dt>
    <dd class="col-sm-10">@Model.Address</dd>
</dl>
<h2 class="h5">Courses</h2>
<ul>
@foreach (var c in Model.Courses.OrderBy(x => x.Name))
{
    <li>@c.Name</li>
}
</ul>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</p>
