@model VcgCollege.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Log in";
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<div class="row justify-content-center py-lg-2">
    <div class="col-md-5 col-lg-4">
        <div class="vcg-auth-card">
            <div class="text-center mb-4">
                <div class="vcg-auth-icon mx-auto mb-3 d-flex align-items-center justify-content-center rounded-3">
                    <i class="bi bi-mortarboard-fill fs-2 text-white" aria-hidden="true"></i>
                </div>
                <h1 class="h4 mb-1">Sign in</h1>
                <p class="text-muted small mb-0">VcgCollege portal</p>
            </div>
            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="All" class="text-danger small"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small"></label>
                    <input asp-for="Email" class="form-control form-control-lg" autocomplete="username" placeholder="you@vcgcollege.local" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold small"></label>
                    <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label small"></label>
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-lg">Log in</button>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
