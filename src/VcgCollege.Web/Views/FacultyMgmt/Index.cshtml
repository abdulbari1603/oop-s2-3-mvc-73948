@model IEnumerable<VcgCollege.Web.Data.Entities.FacultyProfile>
@{
    ViewData["Title"] = "Faculty";
}
<h1 class="h3 mb-3">Faculty</h1>
<p><a class="btn btn-primary" asp-action="Create">Add faculty</a></p>
<div class="table-responsive vcg-table-wrap mb-3"><table class="table table-striped mb-0">
    <thead><tr><th>Name</th><th>Email</th><th>Courses</th><th></th></tr></thead>
    <tbody>
    @foreach (var f in Model)
    {
        <tr>
            <td>@f.Name</td>
            <td>@f.Email</td>
            <td>@f.CourseAssignments.Count</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@f.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@f.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@f.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table></div>
