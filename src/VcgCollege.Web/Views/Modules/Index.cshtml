@model IEnumerable<VcgCollege.Web.Data.Entities.Module>
@{
    ViewData["Title"] = "Modules";
    var filter = ViewBag.CourseFilter as int?;
}
<h1 class="h3 mb-3">Modules</h1>
<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label">Course</label>
        <select name="courseId" class="form-select" asp-items="ViewBag.CourseFilterList">
            <option value="">All</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
    </div>
</form>
<p><a class="btn btn-primary" asp-action="Create" asp-route-courseId="@filter">Create module</a></p>
<div class="table-responsive vcg-table-wrap mb-3"><table class="table table-striped mb-0">
    <thead><tr><th>Course</th><th>Title</th><th>Code</th><th>Credits</th><th></th></tr></thead>
    <tbody>
    @foreach (var m in Model)
    {
        <tr>
            <td>@m.Course?.Name</td>
            <td>@m.Title</td>
            <td>@m.Code</td>
            <td>@m.Credits</td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@m.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@m.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table></div>
