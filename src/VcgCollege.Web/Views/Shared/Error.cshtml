@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="vcg-card border-0 p-4 p-md-5 mx-auto" style="max-width: 40rem;">
    <div class="text-center mb-4">
        <div class="vcg-card-icon mx-auto mb-3"><i class="bi bi-exclamation-octagon" aria-hidden="true"></i></div>
        <h1 class="h3 vcg-page-title">Something went wrong</h1>
        <p class="text-muted mb-0">We could not complete this request. Please try again, or return to the home page.</p>
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="small text-muted text-center mb-0">
            If you need help, mention this reference: <code class="user-select-all">@Model.RequestId</code>
        </p>
    }

    @if (Model.ShowTechnicalDetails && !string.IsNullOrEmpty(Model.TechnicalSummary))
    {
        <div class="alert alert-secondary small mt-4 mb-0" role="status">
            <strong>Development only:</strong> @Model.TechnicalSummary
        </div>
    }

    <div class="d-flex flex-wrap gap-2 justify-content-center mt-4">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Home</a>
        <button type="button" class="btn btn-outline-secondary" onclick="history.back()">Go back</button>
    </div>
</div>
