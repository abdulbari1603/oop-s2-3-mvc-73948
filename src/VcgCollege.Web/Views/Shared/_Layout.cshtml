<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VcgCollege</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 vcg-app">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark vcg-navbar mb-0">
            <div class="container-fluid px-3 px-xl-4">
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole(RoleNames.Faculty) && !User.IsInRole(RoleNames.Administrator))
                {
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Faculty" asp-action="Index">
                        <i class="bi bi-mortarboard-fill text-info" aria-hidden="true"></i>
                        <span>Vcg<span>College</span></span>
                    </a>
                }
                else
                {
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-mortarboard-fill text-info" aria-hidden="true"></i>
                        <span>Vcg<span>College</span></span>
                    </a>
                }
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
                        aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse flex-lg-nowrap align-items-lg-center" id="nav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-2 flex-lg-nowrap">
                        @if (User.Identity?.IsAuthenticated != true || !User.IsInRole(RoleNames.Faculty) || User.IsInRole(RoleNames.Administrator))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>Home</a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole(RoleNames.Administrator))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="AdminHome" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Branches" asp-action="Index"><i class="bi bi-geo-alt me-1"></i>Branches</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Courses" asp-action="Index"><i class="bi bi-book me-1"></i>Courses</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Modules" asp-action="Index"><i class="bi bi-layers me-1"></i>Modules</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Students" asp-action="Index"><i class="bi bi-person-vcard me-1"></i>Students</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="FacultyMgmt" asp-action="Index"><i class="bi bi-person-workspace me-1"></i>Faculty</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Enrolments" asp-action="Index"><i class="bi bi-person-plus me-1"></i>Enrolments</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="AttendanceAdmin" asp-action="Index"><i class="bi bi-calendar-check me-1"></i>Attendance</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="AssignmentsAdmin" asp-action="Index"><i class="bi bi-journal-text me-1"></i>Assignments</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ExamsAdmin" asp-action="Index"><i class="bi bi-clipboard2-pulse me-1"></i>Exams</a></li>
                            }
                            @if (User.IsInRole(RoleNames.Faculty))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Faculty" asp-action="Index"><i class="bi bi-person-video3 me-1"></i>Faculty</a></li>
                            }
                            @if (User.IsInRole(RoleNames.Student))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Index"><i class="bi bi-person-badge me-1"></i>Portal</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Profile"><i class="bi bi-person-lines-fill me-1"></i>My profile</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Assignments"><i class="bi bi-journal-check me-1"></i>Assignments &amp; grades</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Exams"><i class="bi bi-clipboard-data me-1"></i>Exams</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Attendance"><i class="bi bi-calendar-week me-1"></i>Attendance</a></li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item text-lg-end">
                                <span class="navbar-text text-white-50 small d-none d-lg-inline"><i class="bi bi-person-circle me-1"></i></span>
                                <span class="navbar-text text-white-50 small vcg-navbar-user d-inline-block">@User.Identity?.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3">Log out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm rounded-pill px-3 text-dark fw-semibold" asp-controller="Account" asp-action="Login">Log in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="vcg-main flex-grow-1 py-4">
        <div class="container">
            <div class="vcg-alerts">
                <partial name="_FlashMessages" />
            </div>
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>
    <footer class="vcg-footer py-4 mt-auto">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <span><strong class="text-dark">VcgCollege</strong> &mdash; multi-branch student &amp; course management</span>
            <span class="small">&copy; @DateTime.UtcNow.Year</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
