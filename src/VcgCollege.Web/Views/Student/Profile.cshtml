@model VcgCollege.Web.Data.Entities.StudentProfile
@{
    ViewData["Title"] = "My profile";
}
<h1 class="h3 mb-3">My profile</h1>
<p class="text-muted">You can update your phone and address. Contact the office to change your name or email.</p>
<form asp-action="Profile" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" value="@Model.Name" disabled />
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input class="form-control" value="@Model.Email" disabled />
    </div>
    <div class="mb-3">
        <label asp-for="Phone" class="form-label"></label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
