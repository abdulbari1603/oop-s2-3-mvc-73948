@model VcgCollege.Web.Data.Entities.StudentProfile
@{
    ViewData["Title"] = "Student details";
}
<h1 class="h3 mb-3">@Model.Name</h1>
<dl class="row">
    <dt class="col-sm-2">Email</dt><dd class="col-sm-10">@Model.Email</dd>
    <dt class="col-sm-2">Phone</dt><dd class="col-sm-10">@Model.Phone</dd>
    <dt class="col-sm-2">Address</dt><dd class="col-sm-10">@Model.Address</dd>
    <dt class="col-sm-2">DOB</dt><dd class="col-sm-10">@(Model.DateOfBirth?.ToString("d") ?? "—")</dd>
    <dt class="col-sm-2">Student #</dt><dd class="col-sm-10">@Model.StudentNumber</dd>
</dl>
<h2 class="h5">Enrolments</h2>
<ul>
@foreach (var e in Model.Enrolments.OrderBy(x => x.Course!.Name))
{
    <li>@e.Course?.Name — @e.Status (since @e.EnrolDate.ToString("d"))</li>
}
</ul>
<p>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
    <a class="btn btn-secondary" asp-action="Index">Back</a>
</p>
